<?xml version="1.0" encoding="UTF-8"?>
<!--
  State string length = 12  (one character per linkIndex 0-11)

  Position map:
    0-2  north_in movements  ─┐ NS group
    3-5  south_in movements  ─┘
    6-8  east_in  movements  ─┐ EW group
    9-11 west_in  movements  ─┘

  G = protected green   y = yellow   r = red
-->
<tlLogics>

    <tlLogic id="center" type="static" programID="0" offset="0">

        <!-- Phase 0 – North-South GREEN  (30 s) -->
        <!-- NS: GGGGGGrrrrrr  links 0-5 green, 6-11 red -->
        <phase duration="30" state="GGGGGGrrrrrr"
               name="NS_green"/>

        <!-- Phase 1 – North-South YELLOW (3 s) -->
        <phase duration="3"  state="yyyyyyrrrrrr"
               name="NS_yellow"/>

        <!-- Phase 2 – East-West GREEN    (30 s) -->
        <!-- EW: rrrrrrGGGGGG  links 0-5 red, 6-11 green -->
        <phase duration="30" state="rrrrrrGGGGGG"
               name="EW_green"/>

        <!-- Phase 3 – East-West YELLOW   (3 s) -->
        <phase duration="3"  state="rrrrrryyyyyy"
               name="EW_yellow"/>

    </tlLogic>

</tlLogics>
